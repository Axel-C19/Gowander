# ─── Backend ───────────────────────────────────
DATABASE_URL=postgresql://gowander:gowander@localhost:5432/gowander_dev
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Google APIs ───────────────────────────────
GOOGLE_PLACES_API_KEY=your-google-places-key
GOOGLE_MAPS_API_KEY=your-google-maps-key

# ─── Google Sign-In (OAuth) ────────────────────
# Comma-separated OAuth client IDs accepted as token audience. The WEB client
# ID must be FIRST — it drives the server-side flow used by the mobile app.
GOOGLE_OAUTH_CLIENT_IDS=
# The web client's secret (Console → Credentials → your web client)
GOOGLE_OAUTH_CLIENT_SECRET=
# Public https URL of this API, reachable from the phone's browser.
# Dev: run `ngrok http 8000` and paste the https URL here. Register
# <PUBLIC_BASE_URL>/api/v1/auth/google/callback as an authorized redirect
# URI on the web client in Google Console.
PUBLIC_BASE_URL=

# ─── Mobile ────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_MAPS_KEY=your-maps-key
# (Google sign-in is handled server-side — no Google IDs needed on mobile.)

# ─── Environment ───────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=debug
